# ChronoGauntlet model API keys — copy to `.env` (git-ignored) and fill in.
#   cp .env.example .env
# Only the provider(s) you actually run are needed. Real env vars take precedence.
#
# Frontier:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Open-weight (all OpenAI-compatible): pick whichever you have access to.
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
# Optional base-URL overrides (defaults are the provider's public endpoint):
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# TOGETHER_BASE_URL=https://api.together.xyz/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
